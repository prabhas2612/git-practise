<script>
    // 1. SHOPPING CART SYSTEM
    let cartCount = 0;
    
    // Create a visual cart badge inside the navigation bar dynamically
    const nav = document.querySelector('nav');
    const cartBadge = document.createElement('span');
    cartBadge.id = 'cart-counter';
    cartBadge.innerHTML = ' 🛒 Cart: <b>0</b>';
    cartBadge.style.cssText = 'color: #007bff; margin-left: 1.5rem; font-size: 0.95rem; cursor: pointer;';
    nav.appendChild(cartBadge);

    // Grab all the "Add to Cart" buttons on the webpage
    const cartButtons = document.querySelectorAll('.card .btn-sm');

    // Attach click events to every button to update the tally
    cartButtons.forEach(button => {
        button.addEventListener('click', (event) => {
            event.preventDefault(); // Prevents page from jumping or reloading
            cartCount++;
            
            // Update the counter UI text
            document.querySelector('#cart-counter b').innerText = cartCount;
            
            // Visual alert for user confirmation
            const productName = event.target.parentElement.querySelector('h3').innerText;
            alert(`${productName} added to your shopping cart!`);
        });
    });

    // 2. SEARCH INTERACTIVE FILTERING
    // Insert a functional search bar inside the hero section layout
    const heroSection = document.querySelector('.hero');
    const searchContainer = document.createElement('div');
    searchContainer.style.marginTop = '1.5rem';
    
    searchContainer.innerHTML = `
        <input type="text" id="product-search" placeholder="Search gadgets..." 
        style="padding: 0.6rem 1rem; width: 280px; border-radius: 4px 0 0 4px; border: none; outline: none; font-size: 0.95rem;">
        <button style="padding: 0.6rem 1rem; background-color: #007bff; border: none; color: white; border-radius: 0 4px 4px 0; cursor: pointer;">🔍</button>
    `;
    heroSection.appendChild(searchContainer);

    // Real-time keyword filtering logic
    const searchInput = document.getElementById('product-search');
    const productCards = document.querySelectorAll('.card');

    searchInput.addEventListener('input', (e) => {
        const query = e.target.value.toLowerCase().trim();

        productCards.forEach(card => {
            const title = card.querySelector('h3').innerText.toLowerCase();
            
            // Toggle display visibility based on matching text search
            if (title.includes(query)) {
                card.style.display = 'block';
            } else {
                card.style.display = 'none';
            }
        });
    });
</script>

