import random

target = random.randint(1, 10)
guess = 0

print("I am thinking of a number between 1 and 10.")

while guess != target:
    guess = int(input("Take a guess: "))
    
    if guess < target:
        print("Too low!")
    elif guess > target:
        print("Too high!")
    else:
        print("Correct! You win!")

