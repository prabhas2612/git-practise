<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ElectroTech | Premium Gadgets</title>
    <style>
        /* Base Reset */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #f8f9fa;
            color: #333;
        }

        /* Navigation Bar */
        header {
            background-color: #11141a;
            color: white;
            padding: 1rem 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo {
            font-size: 1.5rem;
            font-weight: bold;
            color: #007bff;
        }

        nav a {
            color: white;
            text-decoration: none;
            margin-left: 1.5rem;
            font-size: 0.95rem;
            transition: color 0.3s;
        }

        nav a:hover {
            color: #007bff;
        }

        /* Hero Banner Section */
        .hero {
            background: linear-gradient(135deg, #1e293b, #0f172a);
            color: white;
            padding: 5rem 5%;
            text-align: center;
        }

        .hero h1 {
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }

        .hero p {
            font-size: 1.1rem;
            margin-bottom: 2rem;
            color: #94a3b8;
        }

        .btn {
            background-color: #007bff;
            color: white;
            padding: 0.75rem 2rem;
            border: none;
            border-radius: 4px;
            font-size: 1rem;
            cursor: pointer;
            text-decoration: none;
            font-weight: bold;
            transition: background 0.3s;
        }

        .btn:hover {
            background-color: #0056b3;
        }

        /* Product Grid Section */
        .products-section {
            padding: 4rem 5%;
        }

        .section-title {
            text-align: center;
            font-size: 2rem;
            margin-bottom: 3rem;
            position: relative;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
        }

        /* Product Card Component */
        .card {
            background: white;
            padding: 1.5rem;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            text-align: center;
            transition: transform 0.3s;
        }

        .card:hover {
            transform: translateY(-5px);
        }

        .card-img {
            width: 100%;
            height: 180px;
            background-color: #e2e8f0;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.9rem;
            color: #64748b;
            margin-bottom: 1rem;
            font-weight: 500;
        }

        .card h3 {
            font-size: 1.2rem;
            margin-bottom: 0.5rem;
        }

        .price {
            color: #007bff;
            font-size: 1.2rem;
            font-weight: bold;
            margin-bottom: 1rem;
        }

        .card .btn-sm {
            padding: 0.5rem 1rem;
            font-size: 0.9rem;
            width: 100%;
            display: inline-block;
        }

        /* Footer Section */
        footer {
            background-color: #11141a;
            color: #94a3b8;
            text-align: center;
            padding: 2rem;
            margin-top: 2rem;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>

    <!-- Header / Navigation -->
    <header>
        <div class="logo">⚡ ElectroTech</div>
        <nav>
            <a href="#">Home</a>
            <a href="#">Shop</a>
            <a href="#">Deals</a>
            <a href="#">Contact</a>
        </nav>
    </header>

    <!-- Hero Promotional Banner -->
    <section class="hero">
        <h1>Next-Gen Audio & Visuals</h1>
        <p>Experience crystal clear tech with up to 40% off on premium headphones this week.</p>
        <a href="#" class="btn">Shop New Releases</a>
    </section>

    <!-- Featured Products Showcase -->
    <section class="products-section">
        <h2 class="section-title">Featured Products</h2>
        
        <div class="grid">
            <!-- Product Item 1 -->
            <div class="card">
                <div class="card-img">[ Wireless Headphones Image ]</div>
                <h3>Pro Sound ANC Headphones</h3>
                <p class="price">₹14,999</p>
                <a href="#" class="btn btn-sm">Add to Cart</a>
            </div>

            <!-- Product Item 2 -->
            <div class="card">
                <div class="card-img">[ Smartwatch Image ]</div>
                <h3>FitBand Smartwatch v5</h3>
                <p class="price">₹7,499</p>
                <a href="#" class="btn btn-sm">Add to Cart</a>
            </div>

            <!-- Product Item 3 -->
            <div class="card">
                <div class="card-img">[ Mechanical Keyboard Image ]</div>
                <h3>RGB Mechanical Keyboard</h3>
                <p class="price">₹5,999</p>
                <a href="#" class="btn btn-sm">Add to Cart</a>
            </div>

            <!-- Product Item 4 -->
            <div class="card">
                <div class="card-img">[ UltraWide Monitor Image ]</div>
                <h3>4K UltraWide 34" Monitor</h3>
                <p class="price">₹32,500</p>
                <a href="#" class="btn btn-sm">Add to Cart</a>
            </div>
        </div>
    </section>

    <!-- Footer Summary -->
    <footer>
        <p>&copy; 2026 ElectroTech. All rights reserved. Built with clean HTML & CSS.</p>
    </footer>

</body>
</html>

